# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
SYMFONY_DEPRECATIONS_HELPER=999999
PANTHER_APP_ENV=panther
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots

# Dedicated SQLite test database (lives under the gitignored /var). The
# doctrine `when@test` config appends a "_test" suffix to the dbname, so the
# real file is var/test.db_test — fully isolated from the dev var/data.db.
DATABASE_URL="sqlite:///%kernel.project_dir%/var/test.db"

# Discard all mail in tests; emails are still collected for assertions.
MAILER_DSN=null://null

# Deterministic shortener base for share-link assertions.
SHORTENER_BASE_URL=https://obc.onl
