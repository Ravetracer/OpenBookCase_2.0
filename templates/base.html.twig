<!DOCTYPE html>
{% import 'components/icon.html.twig' as ui %}
<html lang="{{ app.request.locale }}">
    <head>
        <title>{% block title %}{{ 'seo.default_title'|trans }}{% endblock %}</title>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="description" content="{% block meta_description %}{{ 'seo.default_description'|trans }}{% endblock %}">
        <meta name="keywords" content="{% block meta_keywords %}{{ 'seo.keywords'|trans }}{% endblock %}">
        <meta name="author" content="Christian Nielebock">

        {# Canonical URL — pages that exist under more than one path (e.g. `/` and the
           legacy `/map` backlink target) override this block to point at the single
           preferred URL, consolidating SEO signals without a redirect. #}
        <link rel="canonical" href="{% block canonical %}{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}{% endblock %}">

        {# Open Graph / Twitter card — richer link previews + extra ranking signals. #}
        {% set og_title = block('og_title') is defined ? block('og_title') : 'seo.default_title'|trans %}
        {% set og_desc = block('meta_description') %}
        <meta property="og:type" content="website">
        <meta property="og:site_name" content="OpenBookCase">
        <meta property="og:title" content="{{ og_title }}">
        <meta property="og:description" content="{{ og_desc }}">
        <meta property="og:url" content="{{ app.request.uri }}">
        <meta property="og:locale" content="{{ app.request.locale }}">
        <meta property="og:image" content="{{ app.request.schemeAndHttpHost }}/icons/icon-512.png">
        <meta name="twitter:card" content="summary">
        <meta name="twitter:title" content="{{ og_title }}">
        <meta name="twitter:description" content="{{ og_desc }}">
        <meta name="twitter:image" content="{{ app.request.schemeAndHttpHost }}/icons/icon-512.png">

        {# Structured data: tells search engines this is a searchable site, wiring the
           sitelinks search box to the public list search (/list?q=…). #}
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "WebSite",
            "name": "OpenBookCase",
            "url": "{{ app.request.schemeAndHttpHost }}/",
            "description": {{ 'seo.default_description'|trans|json_encode|raw }},
            "inLanguage": "{{ app.request.locale }}",
            "potentialAction": {
                "@type": "SearchAction",
                "target": {
                    "@type": "EntryPoint",
                    "urlTemplate": "{{ app.request.schemeAndHttpHost }}/list?q={search_term_string}"
                },
                "query-input": "required name=search_term_string"
            }
        }
        </script>
        {# Favicons + PWA icons (generated from assets/images/obc2_icon.svg). Paths
           are absolute so they resolve on nested routes like /bookcase/{id}. #}
        <link rel="icon" href="/favicon.ico" sizes="any">
        <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png">
        <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png">
        <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">

        {# Installable web-app (PWA) #}
        <link rel="manifest" href="/manifest.webmanifest">
        <meta name="theme-color" content="#633d0f">
        <meta name="mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="default">
        <meta name="apple-mobile-web-app-title" content="OpenBookCase">

        {# Register the (network-only) service worker that makes the app installable.
           When a new worker activates, reload open tabs once so deployed changes are
           picked up. The reload listener is only attached when a worker already
           controls the page, so the very first visit is never reloaded. #}
        <script>
            if ('serviceWorker' in navigator) {
                window.addEventListener('load', function () {
                    if (navigator.serviceWorker.controller) {
                        var reloaded = false;
                        navigator.serviceWorker.addEventListener('controllerchange', function () {
                            if (reloaded) return;
                            reloaded = true;
                            window.location.reload();
                        });
                    }
                    navigator.serviceWorker.register('/sw.js', { scope: '/', updateViaCache: 'none' });
                });
            }
        </script>

        {# "Install app" button wiring. The button(s) marked [data-install-button] stay
           hidden until the browser fires `beforeinstallprompt` (Chrome/Edge desktop +
           Android). We stash that event and replay it on click. iOS/Safari has no such
           event — there users install via the Share menu, so the button simply stays
           hidden. Already-installed (standalone) launches never show it. #}
        <script>
            (function () {
                var deferredPrompt = null;
                var setVisible = function (visible) {
                    document.querySelectorAll('[data-install-button]').forEach(function (el) {
                        el.hidden = !visible;
                    });
                };
                var standalone = window.matchMedia('(display-mode: standalone)').matches
                    || window.navigator.standalone === true;
                var isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent)
                    || (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1); // iPadOS

                // iOS has no beforeinstallprompt — show the button straight away and
                // open the "Add to Home Screen" instructions on click instead.
                if (isIOS && !standalone) {
                    window.addEventListener('DOMContentLoaded', function () { setVisible(true); });
                }

                window.addEventListener('beforeinstallprompt', function (e) {
                    e.preventDefault(); // suppress Chrome's default mini-infobar
                    deferredPrompt = e;
                    if (!standalone) setVisible(true);
                });

                document.addEventListener('click', function (e) {
                    if (!e.target.closest('[data-install-button], [data-install-button-trigger]')) return;
                    e.preventDefault();
                    if (deferredPrompt) {
                        deferredPrompt.prompt();
                        deferredPrompt.userChoice.finally(function () {
                            deferredPrompt = null; // the prompt event is single-use
                            setVisible(false);
                        });
                    } else if (isIOS) {
                        document.getElementById('installHelpModal').showModal();
                    }
                });

                window.addEventListener('appinstalled', function () {
                    deferredPrompt = null;
                    setVisible(false);
                });
            })();
        </script>

        {# Apply the stored theme before paint to avoid a flash of the wrong theme #}
        <script>
            (function () {
                var t = localStorage.getItem('theme');
                if (t) document.documentElement.setAttribute('data-theme', t);
            })();
        </script>

        {% if not app.user %}
        {# Anonymous locale bridge: the choice lives in localStorage (as requested),
           but server-side translation needs a cookie. If localStorage has a locale
           the server isn't using yet, sync it into the cookie and reload once. #}
        <script>
            (function () {
                var ls = localStorage.getItem('locale');
                if (!ls) return;
                var ck = (document.cookie.match(/(?:^|;\s*)obc_locale=([^;]+)/) || [])[1];
                if (ck !== ls) {
                    document.cookie = 'obc_locale=' + ls + ';path=/;max-age=31536000';
                    location.reload();
                }
            })();
        </script>
        {% endif %}

        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}
    </head>
    <body class="flex flex-col bg-base-100 text-base-content {% block body_class %}min-h-screen{% endblock %}">

        {% if app.environment == 'prod' %}
        {# Matomo — self-hosted, privacy-friendly analytics. Only loaded in production
           (never in dev/test, so local visits don't pollute the stats). `disableCookies`
           keeps it cookieless + consent-free, matching the privacy policy. #}
        <script>
          var _paq = window._paq = window._paq || [];
          _paq.push(['disableCookies']);
          _paq.push(['trackPageView']);
          _paq.push(['enableLinkTracking']);
          (function() {
            var u="https://matomo.openbookcase.de/";
            _paq.push(['setTrackerUrl', u+'matomo.php']);
            _paq.push(['setSiteId', '1']);
            var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
            g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
          })();
        </script>
        <noscript><p><img referrerpolicy="no-referrer-when-downgrade" src="https://matomo.openbookcase.de/matomo.php?idsite=1&amp;rec=1" style="border:0;" alt="" /></p></noscript>
        {% endif %}

        {% include('navigation.html.twig') %}

        {# Global success/error toast (e.g. after a password reset or registration). #}
        {% set globalSuccess = app.flashes('reset_success')|merge(app.flashes('register_success')) %}
        {% set globalError = app.flashes('register_error') %}
        {% if globalSuccess or globalError %}
            <div class="toast toast-top toast-center z-50">
                {% for message in globalSuccess %}
                    <div class="alert alert-success">{{ message }}</div>
                {% endfor %}
                {% for message in globalError %}
                    <div class="alert alert-error">{{ message }}</div>
                {% endfor %}
            </div>
        {% endif %}

        <main class="flex-1 {% block main_class %}{% endblock %}">
            {% block body %}{% endblock %}
        </main>

        {# ───────────────────────── Login modal ───────────────────────── #}
        {% set loginErrors = app.flashes('login_error') %}
        {% set loginLastUsername = app.flashes('login_last_username')|first|default('') %}
        <dialog id="loginModal" class="modal">
            <div class="modal-box">
                <form method="dialog">
                    <button class="btn btn-circle btn-ghost absolute right-3 top-3 text-base-content" aria-label="{{ 'close'|trans }}">{{ ui.icon('close', 'size-5 stroke-[2.5]') }}</button>
                </form>
                <h3 class="mb-4 text-lg font-bold">{{ 'auth.login_title'|trans }}</h3>
                <form method="post" action="{{ path('app_login') }}" class="space-y-4">
                    {% for error in loginErrors %}
                        <div class="alert alert-error" role="alert">{{ error|trans({}, 'security') }}</div>
                    {% endfor %}
                    <div>
                        <label class="label" for="loginUsername"><span class="label-text font-medium">{{ 'auth.username_or_email'|trans }}</span></label>
                        <input type="text" id="loginUsername" name="username" value="{{ loginLastUsername }}" class="input input-bordered w-full" autocomplete="username" required autofocus placeholder="{{ 'auth.username_or_email'|trans }}">
                    </div>
                    <div>
                        <label class="label" for="loginPassword"><span class="label-text font-medium">{{ 'auth.password'|trans }}</span></label>
                        <input type="password" id="loginPassword" name="password" class="input input-bordered w-full" autocomplete="current-password" required>
                        <div class="mt-1 text-right">
                            <a href="{{ path('app_forgot_password') }}" class="link link-hover text-sm text-base-content/70">{{ 'auth.forgot_password'|trans }}</a>
                        </div>
                    </div>
                    <label class="label cursor-pointer justify-start gap-2">
                        <input type="checkbox" name="_remember_me" value="1" class="checkbox checkbox-sm">
                        <span class="label-text">{{ 'auth.remember_me'|trans }}</span>
                    </label>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <div class="modal-action">
                        <button type="button" class="btn btn-ghost" onclick="loginModal.close()">{{ 'cancel'|trans }}</button>
                        <button type="submit" class="btn btn-primary">{{ 'auth.sign_in'|trans }}</button>
                    </div>
                </form>
            </div>
            <form method="dialog" class="modal-backdrop"><button aria-label="{{ 'close'|trans }}">close</button></form>
        </dialog>
        {% if loginErrors %}
            <script>document.getElementById('loginModal').showModal();</script>
        {% endif %}

        {# ───────────────────────── Register modal ───────────────────────── #}
        <dialog id="registerModal" class="modal">
            <div class="modal-box">
                {{ render(controller('App\\Controller\\RegistrationController::registerModal')) }}
            </div>
            <form method="dialog" class="modal-backdrop"><button aria-label="{{ 'close'|trans }}">close</button></form>
        </dialog>

        {# ───────────────────────── Photo management modal ───────────────────────── #}
        <dialog id="photoModal" class="modal" data-controller="photo-modal"
                data-trans-confirm-delete="{{ 'js.confirm_delete_image'|trans }}"
                data-trans-upload-failed="{{ 'js.upload_failed'|trans }}">
            <div class="modal-box max-w-2xl">
                <form method="dialog">
                    <button class="btn btn-circle btn-ghost absolute right-3 top-3 text-base-content" aria-label="{{ 'close'|trans }}">{{ ui.icon('close', 'size-5 stroke-[2.5]') }}</button>
                </form>
                <h3 class="mb-4 text-lg font-bold">{{ 'bookcase.manage_photos'|trans }}</h3>
                <div data-photo-modal-target="body">
                    <div class="flex justify-center py-8"><span class="loading loading-spinner loading-lg"></span></div>
                </div>
            </div>
            <form method="dialog" class="modal-backdrop"><button aria-label="{{ 'close'|trans }}">close</button></form>
        </dialog>

        {# ───────────────────────── Image lightbox ───────────────────────── #}
        <dialog id="lightboxModal" class="modal" data-controller="lightbox"
                data-trans-previous="{{ 'lightbox.previous'|trans }}"
                data-trans-next="{{ 'lightbox.next'|trans }}">
            <div class="modal-box flex max-h-[95vh] w-full max-w-5xl flex-col bg-base-100 p-2 sm:p-4">
                <form method="dialog">
                    <button class="btn btn-circle btn-ghost absolute right-3 top-3 z-10 text-base-content" aria-label="{{ 'close'|trans }}">{{ ui.icon('close', 'size-5 stroke-[2.5]') }}</button>
                </form>
                <div class="relative flex min-h-0 flex-1 items-center justify-center">
                    <img data-lightbox-target="image" src="" alt=""
                         class="max-h-[80vh] w-auto max-w-full object-contain">
                    <button type="button" data-lightbox-target="prev" data-action="lightbox#prev"
                            class="btn btn-circle absolute left-1 top-1/2 -translate-y-1/2 sm:left-2"
                            aria-label="{{ 'lightbox.previous'|trans }}">{{ ui.icon('chevron-left', 'size-5') }}</button>
                    <button type="button" data-lightbox-target="next" data-action="lightbox#next"
                            class="btn btn-circle absolute right-1 top-1/2 -translate-y-1/2 sm:right-2"
                            aria-label="{{ 'lightbox.next'|trans }}">{{ ui.icon('chevron-right', 'size-5') }}</button>
                </div>
                <div class="mt-2 flex items-center justify-between gap-2 text-sm text-base-content/70">
                    <p data-lightbox-target="caption" class="hidden truncate"></p>
                    <span data-lightbox-target="counter" class="ml-auto hidden whitespace-nowrap tabular-nums"></span>
                </div>
            </div>
            <form method="dialog" class="modal-backdrop"><button aria-label="{{ 'close'|trans }}">close</button></form>
        </dialog>

        {# ───────────────────────── Wishlist modal ───────────────────────── #}
        <dialog id="wishlistModal" class="modal" data-controller="wishlist-modal"
                data-trans-confirm-cancel="{{ 'js.confirm_cancel_wish'|trans }}"
                data-trans-add-failed="{{ 'js.add_wish_failed'|trans }}"
                data-trans-update-failed="{{ 'js.could_not_update_wish'|trans }}">
            <div class="modal-box max-w-2xl">
                <form method="dialog">
                    <button class="btn btn-circle btn-ghost absolute right-3 top-3 text-base-content" aria-label="{{ 'close'|trans }}">{{ ui.icon('close', 'size-5 stroke-[2.5]') }}</button>
                </form>
                <h3 class="mb-4 text-lg font-bold">{{ 'wishlist.title'|trans }}</h3>
                <div data-wishlist-modal-target="body">
                    <div class="flex justify-center py-8"><span class="loading loading-spinner loading-lg"></span></div>
                </div>
            </div>
            <form method="dialog" class="modal-backdrop"><button aria-label="{{ 'close'|trans }}">close</button></form>
        </dialog>

        {# ───────────────────────── Messages modal ───────────────────────── #}
        {% if app.user %}
        <dialog id="messageModal" class="modal" data-controller="message-modal">
            <div class="modal-box max-w-2xl">
                <div data-message-modal-target="body">
                    <div class="flex justify-center py-8"><span class="loading loading-spinner loading-lg"></span></div>
                </div>
            </div>
            <form method="dialog" class="modal-backdrop"><button aria-label="{{ 'close'|trans }}">close</button></form>
        </dialog>
        {% endif %}

        {# ───────────────────────── Profile modal ───────────────────────── #}
        {% if app.user %}
        <dialog id="profileModal" class="modal" data-controller="profile"
                data-trans-saved="{{ 'js.saved'|trans }}"
                data-trans-could-not-save="{{ 'js.could_not_save'|trans }}"
                data-trans-confirm-remove-watch="{{ 'js.confirm_remove_watch'|trans }}"
                data-trans-confirm-remove-home="{{ 'js.confirm_remove_home'|trans }}"
                data-trans-could-not-delete="{{ 'js.could_not_delete_account'|trans }}">
            <div class="modal-box max-w-lg">
                {{ render(controller('App\\Controller\\ProfileController::modal')) }}
            </div>
            <form method="dialog" class="modal-backdrop"><button aria-label="{{ 'close'|trans }}">close</button></form>
        </dialog>
        {% endif %}

        {# ───────────────────────── Cookie / privacy notice ───────────────────────── #}
        {# Shown once on the first visit (acknowledgement stored in localStorage).
           Re-openable from the nav "Cookies" link. This site uses only essential +
           functional first-party storage — no tracking/advertising/third-party cookies. #}
        <dialog id="cookieModal" class="modal">
            <div class="modal-box max-w-lg">
                <h3 class="mb-2 flex items-center gap-2 text-lg font-bold">
                    {{ ui.icon('info', 'size-5') }} {{ 'cookies.title'|trans }}
                </h3>
                <p class="mb-4 text-sm text-base-content/80">{{ 'cookies.intro'|trans }}</p>

                <ul class="space-y-3 text-sm">
                    <li>
                        <p class="font-semibold">{{ 'cookies.essential_label'|trans }}</p>
                        <p class="text-base-content/70">{{ 'cookies.essential_desc'|trans }}</p>
                    </li>
                    <li>
                        <p class="font-semibold">{{ 'cookies.preferences_label'|trans }}</p>
                        <p class="text-base-content/70">{{ 'cookies.preferences_desc'|trans }}</p>
                    </li>
                    <li>
                        <p class="font-semibold">{{ 'cookies.maps_label'|trans }}</p>
                        <p class="text-base-content/70">{{ 'cookies.maps_desc'|trans }}</p>
                    </li>
                    <li>
                        <p class="font-semibold">{{ 'cookies.analytics_label'|trans }}</p>
                        <p class="text-base-content/70">{{ 'cookies.analytics_desc'|trans }}</p>
                    </li>
                </ul>

                <p class="mt-4 flex items-center gap-1 text-sm font-medium text-success">
                    {{ ui.icon('check-circle', 'size-4') }} {{ 'cookies.no_tracking'|trans }}
                </p>

                <div class="modal-action items-center justify-between">
                    <a href="{{ path('app_legal') }}" class="link link-hover text-sm">{{ 'cookies.privacy_link'|trans }}</a>
                    <button type="button" class="btn btn-primary" id="cookieAccept">{{ 'cookies.accept'|trans }}</button>
                </div>
            </div>
        </dialog>

        {# ───────────────── iOS "Add to Home Screen" instructions ─────────────────
           iOS fires no `beforeinstallprompt`, so on iPhone/iPad the install button
           opens this dialog instead of a native prompt. #}
        <dialog id="installHelpModal" class="modal">
            <div class="modal-box max-w-sm">
                <form method="dialog">
                    <button class="btn btn-circle btn-ghost absolute right-3 top-3 text-base-content" aria-label="{{ 'close'|trans }}">{{ ui.icon('close', 'size-5 stroke-[2.5]') }}</button>
                </form>
                <h3 class="mb-2 flex items-center gap-2 text-lg font-bold">
                    {{ ui.icon('download', 'size-5') }} {{ 'install.ios_title'|trans }}
                </h3>
                <p class="mb-4 text-sm text-base-content/80">{{ 'install.ios_intro'|trans }}</p>
                <ol class="list-decimal space-y-2 pl-5 text-sm">
                    <li>{{ 'install.ios_step1'|trans }}</li>
                    <li>{{ 'install.ios_step2'|trans }}</li>
                </ol>
                <div class="modal-action">
                    <button type="button" class="btn btn-primary" onclick="installHelpModal.close()">{{ 'cookies.accept'|trans }}</button>
                </div>
            </div>
            <form method="dialog" class="modal-backdrop"><button aria-label="{{ 'close'|trans }}">close</button></form>
        </dialog>

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}

        <script>
            window.addEventListener('DOMContentLoaded', function () {
                {# There can be several theme toggles (desktop bar + mobile burger menu);
                   wire them all and keep them in sync. #}
                var toggles = document.querySelectorAll('[data-theme-toggle]');
                if (!toggles.length) return;
                var current = document.documentElement.getAttribute('data-theme')
                    || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                toggles.forEach(function (t) { t.checked = current === 'dark'; });
                toggles.forEach(function (t) {
                    t.addEventListener('change', function () {
                        var theme = t.checked ? 'dark' : 'light';
                        document.documentElement.setAttribute('data-theme', theme);
                        localStorage.setItem('theme', theme);
                        toggles.forEach(function (o) { o.checked = t.checked; });
                    });
                });
            });

            {# Mirror the language choice to localStorage (the switch route sets the cookie). #}
            document.addEventListener('click', function (event) {
                var link = event.target.closest('[data-locale-link]');
                if (link) localStorage.setItem('locale', link.dataset.locale);
            });

            {# Cookie / privacy notice: open once on the first visit; remember the
               acknowledgement in localStorage. Re-openable via [data-open-cookies]. #}
            (function () {
                var modal = document.getElementById('cookieModal');
                if (!modal) return;
                function ack() { try { localStorage.setItem('cookieConsent', '1'); } catch (e) {} }
                try {
                    if (!localStorage.getItem('cookieConsent')) modal.showModal();
                } catch (e) { /* storage unavailable */ }
                var accept = document.getElementById('cookieAccept');
                if (accept) accept.addEventListener('click', function () { ack(); modal.close(); });
                modal.addEventListener('close', ack);
                document.addEventListener('click', function (event) {
                    if (event.target.closest('[data-open-cookies]')) { event.preventDefault(); modal.showModal(); }
                });
            })();
        </script>
    </body>
</html>
