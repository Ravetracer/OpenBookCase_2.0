{% extends 'base.html.twig' %}
{% import 'components/icon.html.twig' as ui %}

{% block title %}{{ 'admin.users.title'|trans }} – OpenBookCase{% endblock %}

{% block body %}
<div class="container mx-auto max-w-5xl p-4 sm:p-6">
  <div class="mb-4 flex flex-wrap items-center gap-2">
    <a href="{{ path('app_admin_dashboard') }}" class="btn btn-ghost btn-sm gap-1">{{ ui.icon('chevron-left', 'size-4') }} {{ 'admin.back'|trans }}</a>
    <h1 class="text-2xl font-bold">{{ 'admin.users.title'|trans }}</h1>
    <span class="badge badge-ghost">{{ 'admin.users.total'|trans({'%count%': total}) }}</span>
  </div>
  {{ include('admin/_flashes.html.twig') }}

  {# Search #}
  <form method="get" action="{{ path('app_admin_users') }}" class="mb-4 flex flex-wrap items-end gap-2">
    <label class="form-control flex-1">
      <span class="label-text mb-1 text-xs">{{ 'admin.users.search'|trans }}</span>
      <input type="search" name="q" value="{{ q }}" placeholder="{{ 'admin.users.search_placeholder'|trans }}" class="input input-bordered input-sm">
    </label>
    <button class="btn btn-primary btn-sm gap-1">{{ ui.icon('search', 'size-4') }} {{ 'admin.users.search_apply'|trans }}</button>
  </form>

  {% if users is empty %}
    <div class="alert">{{ 'admin.users.none'|trans }}</div>
  {% else %}
    <form method="post" action="{{ path('app_admin_users_bulk') }}" id="bulkForm"
          data-confirm-delete="{{ 'admin.users.bulk_confirm_delete'|trans|e('html_attr') }}"
          data-confirm-suspend="{{ 'admin.users.bulk_confirm_suspend'|trans|e('html_attr') }}">
      <input type="hidden" name="_token" value="{{ csrf_token('admin_users_bulk') }}">
      <input type="hidden" name="q" value="{{ q }}">
      <input type="hidden" name="page" value="{{ page }}">

      {# Bulk action bar — revealed by JS once at least one row is selected #}
      <div id="bulkBar" class="mb-3 flex-wrap items-end gap-3 rounded-box border border-base-300 bg-base-200 p-3" style="display:none">
        <span class="badge badge-neutral badge-lg"><span id="bulkCount">0</span></span>
        <label class="form-control grow">
          <span class="label-text mb-1 text-xs">{{ 'admin.users.bulk_reason_label'|trans }}</span>
          <input type="text" name="reason" class="input input-bordered input-sm w-full" placeholder="{{ 'admin.users.bulk_reason_placeholder'|trans }}">
        </label>
        <div class="flex flex-wrap gap-2">
          <button type="submit" name="action" value="resend" class="btn btn-outline btn-sm gap-1">{{ ui.icon('bell', 'size-4') }} {{ 'admin.users.bulk_action_resend'|trans }}</button>
          <button type="submit" name="action" value="unsuspend" class="btn btn-success btn-outline btn-sm gap-1">{{ ui.icon('check-circle', 'size-4') }} {{ 'admin.users.bulk_action_unsuspend'|trans }}</button>
          <button type="submit" name="action" value="suspend" class="btn btn-warning btn-outline btn-sm gap-1"
                  onclick="return confirm(this.form.dataset.confirmSuspend)">{{ ui.icon('x-circle', 'size-4') }} {{ 'admin.users.bulk_action_suspend'|trans }}</button>
          <button type="submit" name="action" value="delete" class="btn btn-error btn-sm gap-1"
                  onclick="return confirm(this.form.dataset.confirmDelete)">{{ ui.icon('trash', 'size-4') }} {{ 'admin.users.bulk_action_delete'|trans }}</button>
        </div>
      </div>

      <div class="overflow-x-auto rounded-box border border-base-300">
        <table class="table table-zebra table-sm">
          <thead>
            <tr>
              <th class="w-8"><input type="checkbox" id="selectAll" class="checkbox checkbox-sm" aria-label="{{ 'admin.users.select_all'|trans }}"></th>
              <th>{{ 'admin.users.col_username'|trans }}</th>
              <th>{{ 'admin.users.col_email'|trans }}</th>
              <th>{{ 'admin.users.col_status'|trans }}</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {% for u in users %}
              <tr>
                <td><input type="checkbox" name="ids[]" value="{{ u.id }}" class="checkbox checkbox-sm row-check" aria-label="{{ u.username }}"></td>
                <td class="font-medium">{{ u.username }}</td>
                <td class="break-all">{{ u.email }}</td>
                <td class="space-x-1 whitespace-nowrap">
                  {% if 'ROLE_ADMIN' in u.roles %}<span class="badge badge-sm badge-primary">{{ 'admin.users.badge_admin'|trans }}</span>{% endif %}
                  {% if u.isSuspended %}<span class="badge badge-sm badge-error">{{ 'admin.users.badge_suspended'|trans }}</span>{% endif %}
                  {% if u.isVerified %}<span class="badge badge-sm badge-success">{{ 'admin.users.badge_verified'|trans }}</span>{% else %}<span class="badge badge-sm badge-warning">{{ 'admin.users.badge_unverified'|trans }}</span>{% endif %}
                  {% if u.legacyUser and not u.legacyMigrated %}<span class="badge badge-sm badge-ghost">{{ 'admin.users.badge_legacy'|trans }}</span>{% endif %}
                </td>
                <td class="text-right">
                  <a href="{{ path('app_admin_user', {user: u.id}) }}" class="btn btn-ghost btn-xs gap-1">{{ ui.icon('eye', 'size-4') }} {{ 'admin.users.manage'|trans }}</a>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </form>

    {% if pages > 1 %}
      <div class="mt-4 flex justify-center">
        <div class="join">
          {% if page > 1 %}
            <a href="{{ path('app_admin_users', {q: q, page: page - 1}) }}" class="btn btn-sm join-item">«</a>
          {% endif %}
          <span class="btn btn-sm join-item btn-disabled">{{ 'admin.users.page'|trans({'%page%': page, '%pages%': pages}) }}</span>
          {% if page < pages %}
            <a href="{{ path('app_admin_users', {q: q, page: page + 1}) }}" class="btn btn-sm join-item">»</a>
          {% endif %}
        </div>
      </div>
    {% endif %}

    <script>
      (function () {
        var form = document.getElementById('bulkForm');
        if (!form) return;
        var bar = document.getElementById('bulkBar');
        var count = document.getElementById('bulkCount');
        var all = document.getElementById('selectAll');
        var rows = function () { return Array.prototype.slice.call(form.querySelectorAll('.row-check')); };
        function refresh() {
          var checked = rows().filter(function (c) { return c.checked; });
          count.textContent = checked.length;
          bar.style.display = checked.length ? 'flex' : 'none';
          all.checked = checked.length > 0 && checked.length === rows().length;
          all.indeterminate = checked.length > 0 && checked.length < rows().length;
        }
        all.addEventListener('change', function () {
          rows().forEach(function (c) { c.checked = all.checked; });
          refresh();
        });
        rows().forEach(function (c) { c.addEventListener('change', refresh); });
        refresh();
      })();
    </script>
  {% endif %}
</div>
{% endblock %}
