{% extends 'base.html.twig' %}

{% block title %}{{ 'reset.new_title'|trans }} – OpenBookCase{% endblock %}

{% block body %}
<div class="container mx-auto max-w-md p-4 sm:p-8">
  <div class="card border border-base-200 bg-base-100 shadow-sm">
    <div class="card-body">
      <h1 class="card-title">{{ 'reset.new_title'|trans }}</h1>

      {% for e in app.flashes('reset_error') %}
        <div class="alert alert-error" role="alert">{{ e }}</div>
      {% endfor %}

      <form method="post" action="{{ path('app_reset_password', { token: token }) }}" class="mt-4 space-y-4">
        <input type="hidden" name="_token" value="{{ csrf_token('reset_password') }}">
        <div>
          <label class="label" for="new-password"><span class="label-text font-medium">{{ 'reset.new_password_label'|trans }}</span></label>
          <input id="new-password" type="password" name="password" required minlength="6" autocomplete="new-password"
                 class="input input-bordered w-full">
        </div>
        <div>
          <label class="label" for="repeat-password"><span class="label-text font-medium">{{ 'reset.repeat_label'|trans }}</span></label>
          <input id="repeat-password" type="password" name="password_repeat" required minlength="6" autocomplete="new-password"
                 class="input input-bordered w-full">
        </div>
        <button type="submit" class="btn btn-primary w-full">{{ 'reset.save_button'|trans }}</button>
      </form>
    </div>
  </div>
</div>
{% endblock %}
