{% extends 'base.html.twig' %}

{% block title %}{{ 'reset.request_title'|trans }} – OpenBookCase{% endblock %}

{% block body %}
<div class="container mx-auto max-w-md p-4 sm:p-8">
  <div class="card border border-base-200 bg-base-100 shadow-sm">
    <div class="card-body">
      {% for e in app.flashes('reset_error') %}
        <div class="alert alert-error" role="alert">{{ e }}</div>
      {% endfor %}

      {% if sent %}
        <h1 class="card-title">{{ 'reset.sent_title'|trans }}</h1>
        <p class="text-base-content/70">{{ 'reset.sent_message'|trans }}</p>
        <a href="{{ path('app_index') }}" class="btn btn-primary mt-4">{{ 'nav.map'|trans }}</a>
      {% else %}
        <h1 class="card-title">{{ 'reset.request_title'|trans }}</h1>
        <p class="text-base-content/70">{{ 'reset.request_intro'|trans }}</p>
        <form method="post" action="{{ path('app_forgot_password') }}" class="mt-4 space-y-4">
          <input type="hidden" name="_token" value="{{ csrf_token('forgot_password') }}">
          <div>
            <label class="label" for="reset-email"><span class="label-text font-medium">{{ 'reset.email_label'|trans }}</span></label>
            <input id="reset-email" type="email" name="email" required autofocus autocomplete="email"
                   class="input input-bordered w-full">
          </div>
          <button type="submit" class="btn btn-primary w-full">{{ 'reset.send_button'|trans }}</button>
        </form>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
