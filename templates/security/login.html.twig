{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.login_title'|trans }}{% endblock %}

{% block body %}
<div class="container mx-auto flex max-w-md flex-col gap-4 p-4 sm:p-8">
  <div class="card border border-base-300 bg-base-100 shadow-sm">
    <div class="card-body">
      <h1 class="card-title">{{ 'auth.please_sign_in'|trans }}</h1>

      {% if error %}
        <div class="alert alert-error" role="alert">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
      {% endif %}

      {% if app.user %}
        <div class="alert">
          {{ 'auth.logged_in_as'|trans({ '%name%': app.user.userIdentifier }) }}
          <a class="link link-primary" href="{{ path('app_logout') }}">{{ 'nav.logout'|trans }}</a>
        </div>
      {% endif %}

      <form method="post" class="space-y-4">
        <div>
          <label class="label" for="inputUsername"><span class="label-text font-medium">{{ 'auth.username'|trans }}</span></label>
          <input type="text" value="{{ last_username }}" name="username" id="inputUsername" class="input input-bordered w-full" autocomplete="username" required autofocus>
        </div>
        <div>
          <label class="label" for="inputPassword"><span class="label-text font-medium">{{ 'auth.password'|trans }}</span></label>
          <input type="password" name="password" id="inputPassword" class="input input-bordered w-full" autocomplete="current-password" required>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button class="btn btn-primary w-full" type="submit">{{ 'auth.sign_in'|trans }}</button>
      </form>
    </div>
  </div>
</div>
{% endblock %}
