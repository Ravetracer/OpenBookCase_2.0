<div class="grid grid-cols-1 gap-0.5 border-b border-base-200 py-2 last:border-0 sm:grid-cols-3 sm:gap-2">
  <dt class="font-semibold text-base-content/70 {{ extraClasses|default('') }}">{{ label | trans }}</dt>
  <dd class="break-words sm:col-span-2">{% if href|default(false) %}<a href="{{ fieldValue | external_url }}" class="link link-primary" target="_blank" rel="noopener noreferrer">{% endif %}{% if translateFieldValue is defined %}{{ fieldValue | trans({}, 'bookcasetypes') }}{% else %}{{ fieldValue }}{% endif %}{% if href|default(false) %}</a>{% endif %}</dd>
</div>
