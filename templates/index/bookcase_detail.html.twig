{% import 'components/icon.html.twig' as ui %}
{% import 'components/rating.html.twig' as rt %}

<form method="dialog">
  <button class="btn btn-circle btn-ghost absolute right-3 top-3 text-base-content" aria-label="{{ 'close'|trans }}">{{ ui.icon('close', 'size-5 stroke-[2.5]') }}</button>
</form>

<h3 class="mb-4 pr-8 text-lg font-bold">{{ bookcase.title }}</h3>

{# Auto-generated (imported) title — invite the community to give it a real name.
   Name the data source (e.g. OpenStreetMap) when we know it. #}
{% if bookcase.titleProvisional %}
  {% set source_label = { 'osm': 'OpenStreetMap' }[bookcase.source] ?? bookcase.source %}
  <div class="alert alert-info mb-4 py-2 text-sm" role="note">
    {{ ui.icon('info', 'size-4 shrink-0') }}
    <span>{{ source_label
      ? 'bookcase.title_provisional_notice_source'|trans({ '%source%': source_label })
      : 'bookcase.title_provisional_notice'|trans }}</span>
    {% if is_granted('ROLE_USER') %}
      <button type="button" class="btn btn-xs btn-info" data-modal-action="edit" data-bc-id="{{ bookcase.id }}">
        {{ 'bookcase.title_provisional_cta'|trans }}
      </button>
    {% endif %}
  </div>
{% endif %}

{# Image carousel #}
{% if bookcase.images|length > 0 %}
  <div class="carousel mb-4 w-full rounded-box bg-base-200">
    {% for image in bookcase.images %}
      <div id="bc-slide-{{ loop.index }}" class="carousel-item w-full flex-col">
        <div class="relative flex w-full justify-center">
          <img src="/images/{{ image.filename }}" class="max-h-72 w-full cursor-zoom-in object-contain"
               alt="{{ image.altText ?: bookcase.title }}"
               data-lightbox="bc-{{ bookcase.id }}"
               data-lightbox-caption="{{ (image.author ? '© photo by ' ~ image.author : '')|e('html_attr') }}"
               role="button" tabindex="0"
               title="{{ 'lightbox.enlarge'|trans }}" aria-label="{{ 'lightbox.enlarge'|trans }}">
          {% if bookcase.images.count > 1 %}
            <div class="absolute left-2 right-2 top-1/2 flex -translate-y-1/2 justify-between">
              <a href="#bc-slide-{{ loop.first ? bookcase.images.count : loop.index - 1 }}" class="btn btn-circle btn-sm" aria-label="Previous">❮</a>
              <a href="#bc-slide-{{ loop.last ? 1 : loop.index + 1 }}" class="btn btn-circle btn-sm" aria-label="Next">❯</a>
            </div>
          {% endif %}
        </div>
        {% if image.author %}
          <p class="w-full bg-base-300/60 px-2 py-1 text-center text-xs text-base-content/70">© photo by {{ image.author }}</p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
{% endif %}

<dl class="text-sm">
  {{ include('index/snippets/infoRow.html.twig', { label: 'bctype', fieldValue: bookcase.entryTypeValue, translateFieldValue: true }) }}
  {{ include('index/snippets/infoRow.html.twig', { label: 'installationType', fieldValue: bookcase.installationType }) }}
  {{ include('index/snippets/infoRow.html.twig', { label: 'form.is_mobile', fieldValue: bookcase.isMobile ? 'mobile'|trans : 'fixed'|trans }) }}
  <div class="grid grid-cols-1 gap-0.5 border-b border-base-200 py-2 sm:grid-cols-3 sm:gap-2">
    <dt class="font-semibold text-base-content/70">
      {{ 'form.is_bookcrossing_zone'|trans }}
      <a href="https://bookcrossing.com" target="_blank" rel="noopener noreferrer"
         class="ml-1 inline-flex align-text-bottom text-info opacity-70 hover:opacity-100"
         aria-label="{{ 'form.bookcrossing_info'|trans }}"
         title="{{ 'form.bookcrossing_info'|trans }}">{{ ui.icon('info', 'size-4') }}</a>
    </dt>
    <dd class="sm:col-span-2">{{ bookcase.isBookcrossingZone ? 'yes'|trans : 'no'|trans }}</dd>
  </div>
  {{ include('index/snippets/infoRow.html.twig', { label: 'position', fieldValue: bookcase.position.latitude ~ ', ' ~ bookcase.position.longitude }) }}
  {# Structured address if present, else the imported free-text field (same fallback as the list).
     The address embeddable is null for quick-added entries, so guard every access. #}
  {% set a = bookcase.address %}
  {% set addrStructured = a ? [[a.street, a.houseNumber]|filter(v => v)|join(' '), [a.zipcode, a.city]|filter(v => v)|join(' ')]|filter(v => v)|join(', ') : '' %}
  {{ include('index/snippets/infoRow.html.twig', { label: 'address.title', fieldValue: addrStructured ?: (a ? a.additionalData : '') }) }}
  {{ include('index/snippets/infoRow.html.twig', { label: 'openingTimes', fieldValue: bookcase.openingTimes.first ? (bookcase.openingTimes.first.twenty_for_seven is same as (true) ? '24 / 7' : bookcase.openingTimes.first.open_time) : '' }) }}
  {{ include('index/snippets/infoRow.html.twig', { label: 'caretaker', fieldValue: bookcase.caretakers.first ? bookcase.caretakers.first.name : '' }) }}
  {{ include('index/snippets/infoRow.html.twig', { label: 'webpage', fieldValue: bookcase.webpage, href: true }) }}
  {# Free-text comment — only shown when set; preserve the author's line breaks. #}
  {% if bookcase.comment %}
    <div class="grid grid-cols-1 gap-0.5 border-b border-base-200 py-2 sm:grid-cols-3 sm:gap-2">
      <dt class="font-semibold text-base-content/70">{{ 'comment'|trans }}</dt>
      <dd class="whitespace-pre-line break-words sm:col-span-2">{{ bookcase.comment }}</dd>
    </div>
  {% endif %}
  {# Accessibility as a traffic-light status indicator + optional description. #}
  <div class="grid grid-cols-1 gap-0.5 border-b border-base-200 py-2 sm:grid-cols-3 sm:gap-2">
    <dt class="font-semibold text-base-content/70">{{ 'accessibility' | trans }}</dt>
    <dd class="sm:col-span-2">
      {% set lvl = bookcase.accessibility.level %}
      {% if lvl %}
        <div class="flex items-center gap-2">
          <span class="status status-xl status-{{ lvl.color }}" aria-hidden="true"></span>
          <span>{{ ('accessibility_level.' ~ lvl.labelKey)|trans }}</span>
        </div>
      {% else %}–{% endif %}
      {% if bookcase.accessibility.description %}
        <p class="mt-1 text-sm text-base-content/70">{{ bookcase.accessibility.description }}</p>
      {% endif %}
    </dd>
  </div>
  {# Availability status: green tick when active, red cross + disclaimer when inactive. #}
  {% set isActive = bookcase.active.statusValue != 'inactive' %}
  <div class="grid grid-cols-1 gap-0.5 border-b border-base-200 py-2 sm:grid-cols-3 sm:gap-2">
    <dt class="font-semibold text-base-content/70">{{ 'status' | trans }}</dt>
    <dd class="sm:col-span-2">
      {% if isActive %}
        <div class="flex items-center gap-2 text-success">
          {{ ui.icon('check-circle', 'size-5') }}
          <span>{{ 'list.active' | trans }}</span>
        </div>
      {% else %}
        <div class="flex items-center gap-2 text-error">
          {{ ui.icon('x-circle', 'size-5') }}
          <span>{{ 'list.inactive' | trans }}</span>
        </div>
        {% if bookcase.active.statusDescription %}
          <p class="mt-1 text-sm text-base-content/70">{{ bookcase.active.statusDescription }}</p>
        {% endif %}
      {% endif %}
    </dd>
  </div>
  <div class="grid grid-cols-1 gap-0.5 border-b border-base-200 py-2 last:border-0 sm:grid-cols-3 sm:items-center sm:gap-2">
    <dt class="font-semibold text-base-content/70">{{ 'rating' | trans }}</dt>
    <dd class="sm:col-span-2">
      <div class="flex flex-col items-start gap-2 sm:flex-row sm:items-center sm:gap-3">
        <span data-rating-display
              title="{{ rating.count > 0 ? (rating.average|number_format(1)) ~ ' / 5 (' ~ rating.count ~ ')' : 'bookcase.no_ratings'|trans }}">
          {{ rt.hearts(rating.rounded) }}
        </span>

        {% if is_granted('ROLE_USER') %}
          <div class="dropdown dropdown-start sm:dropdown-end" data-user-rating data-bc-id="{{ bookcase.id }}">
            <button tabindex="0" type="button" class="btn btn-xs btn-outline gap-1">
              {{ ui.icon('edit', 'size-3') }} {{ 'bookcase.rate'|trans }}
            </button>
            <div tabindex="0" class="dropdown-content z-10 mt-2 w-56 rounded-box border border-base-300 bg-base-100 p-3 shadow-lg">
              <p class="mb-2 text-sm font-medium">{{ 'bookcase.your_rating'|trans }}</p>
              {{ rt.hearts(userRating, true) }}
              <span data-rating-status class="mt-2 block text-xs text-success" aria-live="polite"></span>
            </div>
          </div>
        {% endif %}
      </div>
    </dd>
  </div>
</dl>

{# Shareable short link via the obc.onl shortener; falls back to the full deep
   link if a short code somehow isn't set yet. #}
<div class="mt-4">
  <label class="label" for="bc-share-url"><span class="label-text font-medium">{{ 'shareLink' | trans }}</span></label>
  <div class="join w-full">
    <input id="bc-share-url" type="text" readonly data-share-url
           class="input input-bordered join-item w-full"
           value="{{ bookcase.shortCode ? (shortener_base_url ~ '/' ~ bookcase.shortCode) : url('app_bookcase_show', { bookcase: bookcase.id }) }}"
           onclick="this.select()">
    <button type="button" class="btn join-item gap-1" data-modal-action="copy-link">
      {{ ui.icon('external', 'size-4') }} {{ 'copy' | trans }}
    </button>
  </div>
</div>

<div class="modal-action mt-6 flex-col items-stretch gap-0">
  {# Entry actions: wishlist / watchlist / photos on one line. #}
  <div class="flex flex-wrap justify-center gap-2">
    <button type="button" class="btn btn-outline gap-1" data-modal-action="wishlist" data-bc-id="{{ bookcase.id }}">
      {{ ui.icon('heart', 'size-4') }} {{ 'bookcase.wishlist'|trans }} (<span data-wishlist-count>{{ wishlistOpenCount }}</span>)
    </button>
    {% if is_granted('ROLE_USER') %}
      <button type="button" class="btn gap-1 {{ isWatching ? 'btn-secondary' : 'btn-outline' }}"
              data-modal-action="toggle-watch" data-bc-id="{{ bookcase.id }}" data-watching="{{ isWatching ? '1' : '0' }}"
              data-watch-label-on="{{ 'bookcase.watching'|trans }}" data-watch-label-off="{{ 'bookcase.watch'|trans }}">
        {{ ui.icon('eye', 'size-4') }} <span data-watch-label>{{ isWatching ? 'bookcase.watching'|trans : 'bookcase.watch'|trans }}</span>
      </button>
      <button type="button" class="btn btn-outline gap-1" data-modal-action="photos" data-bc-id="{{ bookcase.id }}">
        {{ ui.icon('photo', 'size-4') }} {{ 'bookcase.photos'|trans }} ({{ bookcase.images|length }})
      </button>
    {% endif %}
  </div>

  <div class="divider my-3"></div>

  {# Dialog controls: Close on the left, Edit on the right. (Delete lives in the
     edit dialog — it's a management action.) #}
  <div class="flex items-center justify-between gap-2">
    <button type="button" class="btn btn-ghost" data-modal-action="close">{{ 'close' | trans }}</button>
    {% if is_granted('ROLE_USER') %}
      <button type="button" class="btn btn-primary gap-1" data-modal-action="edit" data-bc-id="{{ bookcase.id }}">
        {{ ui.icon('edit', 'size-4') }} {{ 'edit' | trans }}
      </button>
    {% endif %}
  </div>
</div>
