{% import 'components/icon.html.twig' as ui %}

<form method="dialog">
    <button class="btn btn-circle btn-ghost absolute right-3 top-3 text-base-content" aria-label="{{ 'close'|trans }}">{{ ui.icon('close', 'size-5 stroke-[2.5]') }}</button>
</form>

<h3 class="mb-4 text-lg font-bold">{{ 'messages.title'|trans }}</h3>

{% if messages is empty %}
    <div class="flex flex-col items-center gap-2 py-10 text-base-content/60">
        {{ ui.icon('inbox', 'size-10') }}
        <p>{{ 'messages.none'|trans }}</p>
    </div>
{% else %}
    {# At most one open application thread per user (only one live application allowed),
       so a single reply box at the end covers the conversation. #}
    {% set threadApp = null %}
    {% for message in messages %}
        {% if message.apiApplication and message.apiApplication.status.value == 'pending' %}{% set threadApp = message.apiApplication %}{% endif %}
    {% endfor %}

    <div class="max-h-[60vh] space-y-1 overflow-y-auto pr-1">
        {% for message in messages %}
            <div class="chat chat-start">
                <div class="chat-image avatar avatar-placeholder">
                    <div class="flex w-10 items-center justify-center rounded-full bg-primary text-primary-content">
                        {{ ui.icon(message.type.icon, 'size-5') }}
                    </div>
                </div>
                <div class="chat-header">
                    {{ message.sender ? message.sender.userIdentifier : 'messages.system'|trans }}
                    <time class="text-xs opacity-50" datetime="{{ message.createdAt|date('c') }}">{{ message.createdAt|date('d M Y, H:i') }}</time>
                </div>
                <div class="chat-bubble {{ message.readAt is null ? 'chat-bubble-primary' : '' }}">
                    {% if message.subject %}<div class="font-semibold">{{ message.subject }}</div>{% endif %}
                    <div class="whitespace-pre-line">{{ message.body }}</div>
                    {% if message.relatedBookcase %}
                        <a href="{{ path('app_bookcase_show', { bookcase: message.relatedBookcase.id }) }}"
                           class="link link-hover mt-1 inline-flex items-center gap-1 text-sm">
                            {{ ui.icon('map', 'size-4') }} {{ 'messages.view_bookcase'|trans }}
                        </a>
                    {% endif %}
                </div>
                {% if message.readAt is null %}
                    <div class="chat-footer opacity-70"><span class="badge badge-xs badge-primary">{{ 'messages.new'|trans }}</span></div>
                {% endif %}
            </div>
        {% endfor %}
    </div>

    {# Reply box — the one place the inbox is two-way: an applicant answering the
       admin inside their pending API-access application thread. Injected fragment,
       so it carries plain data-* and is handled by message_modal_controller (delegation). #}
    {% if threadApp %}
        <form data-msg-reply action="{{ path('app_api_application_reply', {application: threadApp.id}) }}" class="mt-3 space-y-2 border-t border-base-200 pt-3">
            <input type="hidden" name="_token" value="{{ csrf_token('api_reply') }}">
            <label class="label-text text-sm font-medium">{{ 'messages.reply_label'|trans({'%app%': threadApp.appName}) }}</label>
            <textarea name="body" rows="2" required class="textarea textarea-bordered textarea-sm w-full" placeholder="{{ 'messages.reply_placeholder'|trans }}"></textarea>
            <button type="submit" class="btn btn-primary btn-sm">{{ 'messages.reply_send'|trans }}</button>
        </form>
    {% endif %}
{% endif %}
