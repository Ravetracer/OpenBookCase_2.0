<section id="terms" class="card mb-6 scroll-mt-20 bg-base-200">
  <div class="card-body">
    <h2 class="card-title">{{ ui.icon('book', 'size-5') }} Condiciones de los datos y atribución</h2>
    {{ include('static/_data_terms.html.twig') }}
  </div>
</section>
