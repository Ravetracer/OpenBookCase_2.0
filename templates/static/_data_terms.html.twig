{# Shared ODbL / OpenStreetMap data-usage terms list. Included by the JSON-export
   terms dialog (/list) and the API-access application form (profile), so both show
   the identical terms. #}
{% import 'components/icon.html.twig' as ui %}

{% set odbl_link %}<a class="link link-primary" href="https://opendatacommons.org/licenses/odbl/" target="_blank" rel="noopener noreferrer">Open Database License (ODbL)</a>{% endset %}
{% set osm_link %}<a class="link link-primary" href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener noreferrer">{{ 'list.export_terms_osm_label'|trans }}</a>{% endset %}

<ul class="space-y-3 text-sm">
  <li class="flex gap-2">
    <span class="text-primary">{{ ui.icon('book', 'mt-0.5 size-5 shrink-0') }}</span>
    <span>{{ 'list.export_terms_odbl'|trans({'%odbl%': odbl_link})|raw }}</span>
  </li>
  <li class="flex gap-2">
    <span class="text-primary">{{ ui.icon('book', 'mt-0.5 size-5 shrink-0') }}</span>
    <span>{{ 'list.export_terms_sharealike'|trans }}</span>
  </li>
  <li class="flex gap-2">
    <span class="text-primary">{{ ui.icon('map', 'mt-0.5 size-5 shrink-0') }}</span>
    <span>{{ 'list.export_terms_attribution'|trans({'%osm%': osm_link})|raw }}</span>
  </li>
  <li class="flex gap-2">
    <span class="text-warning">{{ ui.icon('warning', 'mt-0.5 size-5 shrink-0') }}</span>
    <span>{{ 'list.export_terms_no_reimport'|trans }}</span>
  </li>
</ul>
