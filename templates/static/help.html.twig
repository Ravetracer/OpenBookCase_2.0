{% extends 'base.html.twig' %}

{% block title %}{{ 'static.help.title'|trans }} – OpenBookCase{% endblock %}

{% block body %}
<div class="container mx-auto max-w-4xl p-4 sm:p-8">
  {# German + English are written; other locales fall back to English. #}
  {% set localized = app.request.locale in ['de', 'en'] ? app.request.locale : 'en' %}
  {{ include('static/help/' ~ localized ~ '.html.twig') }}
</div>
{% endblock %}
