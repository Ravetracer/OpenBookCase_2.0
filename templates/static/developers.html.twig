{% extends 'base.html.twig' %}

{% block title %}{{ 'static.developers.title'|trans }} – OpenBookCase{% endblock %}

{% block body %}
<div class="container mx-auto max-w-4xl p-4 sm:p-8">
  {# All six UI locales are written; anything unexpected falls back to English (like /help + /changelog). #}
  {% set localized = app.request.locale in ['de', 'en', 'ru', 'nl', 'es', 'fr'] ? app.request.locale : 'en' %}
  {{ include('static/developers/' ~ localized ~ '.html.twig') }}
</div>
{% endblock %}
