{% extends 'base.html.twig' %}

{% block title %}{{ 'static.changelog.title'|trans }} – OpenBookCase{% endblock %}

{% block body %}
<div class="container mx-auto max-w-3xl p-4 sm:p-8">
  {# All six UI locales are written; anything unexpected falls back to English.
     To add a release, edit the partial for EVERY locale: static/changelog/{de,en,ru,nl,es,fr}.html.twig — see CLAUDE.md. #}
  {% set localized = app.request.locale in ['de', 'en', 'ru', 'nl', 'es', 'fr'] ? app.request.locale : 'en' %}
  {{ include('static/changelog/' ~ localized ~ '.html.twig') }}
</div>
{% endblock %}
