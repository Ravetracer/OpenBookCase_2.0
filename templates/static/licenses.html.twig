{% extends 'base.html.twig' %}

{% block title %}{{ 'static.licenses.title'|trans }} – OpenBookCase{% endblock %}

{% block body %}
<div class="container mx-auto max-w-3xl p-4 sm:p-8">
  <article class="prose max-w-none">
    <h1>{{ 'static.licenses.title'|trans }}</h1>
    <p class="lead text-base-content/70">{{ 'static.licenses.lead'|trans }}</p>

    <p>{{ 'static.licenses.intro'|trans }}</p>

    <h2>{{ 'static.licenses.code_title'|trans }}</h2>
    {% set source_code_link %}<a class="link link-primary" href="https://github.com/Ravetracer/OpenBookCase_2.0" target="_blank" rel="noopener noreferrer">{{ 'static.licenses.source_code_term'|trans }}</a>{% endset %}
    <p>{{ 'static.licenses.code_body'|trans({'%source_code%': source_code_link})|raw }}
      <a class="link link-primary" href="https://opensource.org/license/MIT" target="_blank" rel="noopener noreferrer">MIT License</a>.</p>

    <h2>{{ 'static.licenses.data_title'|trans }}</h2>
    <p>{{ 'static.licenses.data_body'|trans }}
      <a class="link link-primary" href="https://opendatacommons.org/licenses/odbl/" target="_blank" rel="noopener noreferrer">Open Database License (ODbL)</a>.</p>
    {% set osm_link %}<a class="link link-primary" href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener noreferrer">OpenStreetMap</a>{% endset %}
    <p>{{ 'static.licenses.data_attribution'|trans({'%osm%': osm_link})|raw }}</p>
  </article>
</div>
{% endblock %}
